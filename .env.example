# Tirta Sanita Outbound - Environment Configuration Template
# Copy this file to .env and update with your actual values
# Never commit .env file to version control!

# ======================
# DATABASE CONFIGURATION
# ======================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tirtasanita_db
DB_USER=root
DB_PASS=

# ======================
# MIDTRANS PAYMENT GATEWAY
# ======================
# Get these from: https://midtrans.com/
# Dashboard > Settings > Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ======================
# APPLICATION SETTINGS
# ======================
APP_ENV=development
APP_DEBUG=true
APP_NAME=Tirta Sanita Outbound

# ======================
# EMAIL CONFIGURATION
# ======================
# Option 1: PHP mail() function (default)
MAIL_DRIVER=php

# Option 2: SMTP Server
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_FROM=noreply@tirtasanita.com

# ======================
# SESSION CONFIGURATION
# ======================
SESSION_LIFETIME=3600
SESSION_SECURE=false

# ======================
# LOGGING
# ======================
LOG_LEVEL=error
LOG_PATH=/logs

# ======================
# SERVER CONFIGURATION (Optional)
# ======================
# BASE_URL=http://localhost/tirtasanita
# For production: https://yourdomain.com
