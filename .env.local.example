# Tirta Sanita Outbound - Local Environment Template
# Copy this file to .env.local and add your actual credentials
# NEVER commit .env.local to version control!

# ======================
# DATABASE CONFIGURATION
# ======================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tirtasanita_db
DB_USER=root
DB_PASS=

# ======================
# MIDTRANS PAYMENT GATEWAY
# ======================
# Get these from: https://midtrans.com/
# Dashboard > Settings > Access Keys
MIDTRANS_SERVER_KEY=YOUR_SERVER_KEY_HERE
MIDTRANS_CLIENT_KEY=YOUR_CLIENT_KEY_HERE
MIDTRANS_IS_PRODUCTION=false

# Example (for reference only - update with your actual keys):
# MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxx
# MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxx

# ======================
# APPLICATION SETTINGS
# ======================
APP_ENV=development
APP_DEBUG=true
APP_NAME=Tirta Sanita Outbound

# ======================
# EMAIL CONFIGURATION
# ======================
MAIL_DRIVER=php
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_FROM=noreply@tirtasanita.com

# ======================
# SESSION CONFIGURATION
# ======================
SESSION_LIFETIME=3600
SESSION_SECURE=false
